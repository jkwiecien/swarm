{
	"name": "swarm",
	"version": "0.1.0",
	"description": "Local-First, Federated Multi-Agent Framework for automating software engineering workflows",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"swarm": "./bin/swarm.js"
	},
	"scripts": {
		"swarm": "node --import tsx/esm src/cli/index.ts",
		"dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
		"dev:router": "node --env-file=.env bin/kill-port.js ROUTER_PORT && node --env-file=.env --import tsx/esm --watch src/router/index.ts",
		"dev:dashboard": "node --env-file=.env bin/kill-port.js DASHBOARD_PORT && node --env-file=.env --import tsx/esm --watch src/dashboard.ts",
		"dev:worker": "node --env-file=.env --import tsx/esm --watch src/worker/index.ts",
		"dev:worker:seed": "npm run db:seed && npm run dev:worker",
		"dev:web": "cd web && npx vite",
		"build:web": "cd web && npm run build",
		"typecheck:web": "cd web && npx tsc -b --noEmit",
		"build": "tsc && tsc-alias",
		"start": "node dist/index.js",
		"start:dashboard": "npm run build:web && npm run dev:dashboard",
		"start:worker": "node --env-file=.env dist/worker/index.js",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "node --env-file=.env ./node_modules/.bin/drizzle-kit migrate",
		"db:seed": "node --env-file=.env --import tsx/esm src/cli/index.ts config apply",
		"worktrees:prune": "node --env-file=.env --import tsx/esm src/cli/index.ts worktrees prune",
		"db:push": "node --env-file=.env ./node_modules/.bin/drizzle-kit push",
		"db:studio": "node --env-file=.env ./node_modules/.bin/drizzle-kit studio",
		"test": "vitest run --project unit",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project integration",
		"test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
		"test:db:down": "docker compose -f docker-compose.test.yml down -v",
		"test:all": "vitest run",
		"test:watch": "vitest --project unit",
		"test:coverage": "vitest run --project unit --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
		"verify": "npm run lint && npm run typecheck && npm test",
		"prepare": "lefthook install"
	},
	"keywords": [
		"ai",
		"llm",
		"agents",
		"automation",
		"github",
		"local-first"
	],
	"author": "Jacek Kwiecien",
	"license": "MIT",
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.14",
		"@hono/trpc-server": "^0.4.2",
		"@octokit/rest": "^22.0.1",
		"@trpc/server": "^11.10.0",
		"bullmq": "^5.79.2",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.27",
		"ioredis": "^5.10.1",
		"pg": "^8.22.0",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@commitlint/cli": "^20.1.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@types/node": "^22.10.2",
		"@types/pg": "^8.20.0",
		"@vitest/coverage-v8": "^3.2.4",
		"drizzle-kit": "^0.31.10",
		"lefthook": "^1.10.10",
		"tsc-alias": "^1.9.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"vitest": "^3.2.4"
	}
}
