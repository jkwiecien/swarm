# Node.js
# No trailing slash: also ignores a `node_modules` symlink (git worktrees graft one in
# per ai/ARCHITECTURE.md), not just a real directory — see #32.
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.npm
.node_repl_history
*.tgz
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# SWARM project config scaffolded by `swarm init` — per-user (repo paths, board
# IDs, credential references), not committed. See src/cli/commands/init.ts.
swarm.config.json

