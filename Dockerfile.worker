# Worker image — consumes queued jobs and drives the worktree/harness lifecycle.
# The consumer wiring is in place (SWARM-17), but the image still lacks git and
# the agent-CLI runtimes (claude / antigravity), so a containerized worker can
# only complete jobs as no-ops today — installing that tooling is a follow-up
# tracked on the board.
FROM node:22-slim AS builder
WORKDIR /app

# --ignore-scripts skips the lefthook `prepare` hook, which needs a git repo.
COPY package*.json ./
RUN npm ci --ignore-scripts

COPY tsconfig.json ./
COPY src ./src
RUN npm run build

FROM node:22-slim AS production
WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev --ignore-scripts

COPY --from=builder /app/dist ./dist

CMD ["node", "dist/worker/index.js"]
