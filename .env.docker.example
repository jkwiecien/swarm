# SWARM Docker Compose configuration.
# Copy to .env and adjust values: cp .env.docker.example .env

# --- PostgreSQL ---
POSTGRES_PASSWORD=swarm

# Host-side connection string for the `db:*` npm scripts (drizzle-kit runs on
# the host, not in a container). The port must match POSTGRES_PORT below (SWARM
# publishes Postgres on 5433 by default, offset from the 5432 default so it can
# run alongside Cascade). The router/worker containers get their own
# DATABASE_URL from docker-compose.yml and ignore this.
DATABASE_URL=postgresql://swarm:swarm@localhost:5433/swarm

# The local Postgres serves no TLS; keep SSL off for host-side connections too.
DATABASE_SSL=false

# --- Redis (BullMQ) ---
# The worker runs on the host (not in Compose — it needs the developer's PATH,
# auth, and the agent CLIs), so it connects to Redis over the published host
# port. Must match REDIS_PORT below (default 6380, offset from Redis' 6379). The
# router container gets its own REDIS_URL from docker-compose.yml and ignores
# this.
REDIS_URL=redis://localhost:6380

# --- Credential encryption at rest ---
# 32-byte (64-char) hex key that encrypts credentials stored in the
# project_credentials table (AES-256-GCM). Leave unset for local dev — secrets
# are then stored as plaintext. Generate one with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_MASTER_KEY=

# --- Structured logging (src/lib/logger.ts) ---
# Applies to both the router (container) and the host worker. LEVEL is the
# minimum emitted level (debug|info|warn|error, default info).
SWARM_LOG_LEVEL=info
# FORMAT is json|pretty. Leave unset (don't set it here) so each process
# auto-picks for itself: the router's own docker-compose.yml environment block
# defaults it to json for that container regardless of this file, while the
# host worker sees no SWARM_LOG_FORMAT at all and auto-detects pretty on an
# interactive terminal. Setting it here would override BOTH processes at
# once — the router (correctly staying json) and the worker (losing pretty,
# color, and the readable key=value context it exists for).
#SWARM_LOG_FORMAT=

# --- Cloudflare Tunnel (optional; docs/cloudflare-tunnel.md, Path C) ---
# Token for a dashboard-created tunnel (Cloudflare Zero Trust → Networks →
# Tunnels → "Install and run a connector"). Leave both unset to skip it
# entirely and run cloudflared yourself (Paths A/B), or fill both in to have
# Compose run it as a container alongside the rest of the stack.
CLOUDFLARE_TUNNEL_TOKEN=
# Activates the cloudflared service above — docker compose reads this itself.
COMPOSE_PROFILES=tunnel

# --- Ports (host-side) ---
# Offset from Cascade's defaults (router 3000, Postgres 5432, Redis 6379) so
# both stacks can run in parallel without a host-port clash. Only the published
# host ports change; inside the compose network the services still listen on
# their standard ports.
ROUTER_PORT=3100
POSTGRES_PORT=5433
REDIS_PORT=6380
