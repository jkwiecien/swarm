# SWARM Docker Compose configuration.
# Copy to .env and adjust values: cp .env.docker.example .env

# --- PostgreSQL ---
POSTGRES_PASSWORD=swarm

# Host-side connection string for the `db:*` npm scripts (drizzle-kit runs on
# the host, not in a container). Must match POSTGRES_PASSWORD / POSTGRES_PORT
# above. The router/worker containers get their own DATABASE_URL from
# docker-compose.yml and ignore this.
DATABASE_URL=postgresql://swarm:swarm@localhost:5432/swarm

# --- Credential encryption at rest ---
# 32-byte (64-char) hex key that encrypts credentials stored in the
# project_credentials table (AES-256-GCM). Leave unset for local dev — secrets
# are then stored as plaintext. Generate one with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_MASTER_KEY=

# --- Ports (host-side) ---
ROUTER_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
