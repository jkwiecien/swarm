# SWARM Docker Compose configuration.
# Copy to .env and adjust values: cp .env.docker.example .env

# --- PostgreSQL ---
POSTGRES_PASSWORD=swarm

# Host-side connection string for the `db:*` npm scripts (drizzle-kit runs on
# the host, not in a container). The port must match POSTGRES_PORT below (SWARM
# publishes Postgres on 5433 by default, offset from the 5432 default so it can
# run alongside Cascade). The router/worker containers get their own
# DATABASE_URL from docker-compose.yml and ignore this.
DATABASE_URL=postgresql://swarm:swarm@localhost:5433/swarm

# The local Postgres serves no TLS; keep SSL off for host-side connections too.
DATABASE_SSL=false

# --- Redis (BullMQ) ---
# The worker runs on the host (not in Compose — it needs the developer's PATH,
# auth, and the agent CLIs), so it connects to Redis over the published host
# port. Must match REDIS_PORT below (default 6380, offset from Redis' 6379). The
# router container gets its own REDIS_URL from docker-compose.yml and ignores
# this.
REDIS_URL=redis://localhost:6380

# How many BullMQ jobs the worker processes at once. Defaults to 1 (serial) if
# unset. PR review-lifecycle jobs always queue ahead of PM-board jobs
# regardless of this value (src/queue/producer.ts's priorityFor) — raising
# this lets a review run concurrently with a still-in-flight planning or
# implementation phase instead of just changing the order they run in.
#SWARM_WORKER_CONCURRENCY=2

# Raw credential printed once by `swarm workers register`. Set this on each
# federated worker host so the process can acquire/heartbeat that registered
# worker's fenced session and execute only dispatches selected for it. A worker
# without this value can serve unfederated projects, but never an enrolled one.
#SWARM_WORKER_CREDENTIAL=

# Dependency-blocked Implementation re-check (issue #330). An Implementation whose
# work item is `blocked by` an unfinished issue is deferred and re-checked on this
# interval — a token-free check (no worktree, no agent) — until the prerequisite
# closes, or SWARM_DEPENDENCY_MAX_WAIT_MS elapses and it fails with a "must be done
# first" comment. Defaults: 5 minutes / 7 days.
#SWARM_DEPENDENCY_RECHECK_MS=300000
#SWARM_DEPENDENCY_MAX_WAIT_MS=604800000

# Global emergency switch for curated native semantic delegation. Projects and
# phases remain opted out unless agents.delegation enables them; set this false
# to disable every native child without editing/re-applying project config.
SWARM_NATIVE_DELEGATION_ENABLED=true

# --- Credential encryption at rest ---
# 32-byte (64-char) hex key that encrypts credentials stored in the
# project_credentials table (AES-256-GCM). Leave unset for local dev — secrets
# are then stored as plaintext. Generate one with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_MASTER_KEY=

# --- API server auth (src/api/server.ts) ---
# Local single-user mode (issue #298). Enabled here so this Docker template gives
# a zero-setup local install: the API resolves a passwordless localhost-admin on
# its own, so you skip `swarm users add` / `set-password`, the /login screen, and
# session cookies entirely. The environment variable itself DEFAULTS TO DISABLED
# when absent — only the literal `true` turns it on — so the coded behavior stays
# the multi-user, session-cookie policy below. Not consumed by the router
# container (it has no dashboard identity boundary); the API and host worker read
# it from this file.
SWARM_SINGLE_USER_MODE=true
#
# Multi-user alternative: set SWARM_SINGLE_USER_MODE=false (or remove the line
# above) to require per-user session auth (issue #281 task 2) instead — no shared
# secret; DASHBOARD_TOKEN has been retired. Then create a user and set its
# password with the operator CLI, and sign in at /login:
#   swarm users add you@example.com --admin
#   swarm users set-password you@example.com
# Optional: override the session lifetime (default 168 hours = 7 days).
# SWARM_SESSION_TTL_HOURS=168
# Optional: credentialed CORS allow-list (comma-separated origins) for the
# separate-origin setup — SPA and API on different origins. Only needed then;
# the same-origin deploy never pre-flights. The default already permits the
# Vite dev server, so `npm run dev` works unchanged. Never "*".
# CORS_ORIGIN=http://localhost:5173

# --- Structured logging (src/lib/logger.ts) ---
# Applies to both the router (container) and the host worker. LEVEL is the
# minimum emitted level (debug|info|warn|error, default info).
SWARM_LOG_LEVEL=info
# FORMAT is json|pretty. Leave unset (don't set it here) so each process
# auto-picks for itself: the router's own docker-compose.yml environment block
# defaults it to json for that container regardless of this file, while the
# host worker sees no SWARM_LOG_FORMAT at all and auto-detects pretty on an
# interactive terminal. Setting it here would override BOTH processes at
# once — the router (correctly staying json) and the worker (losing pretty,
# color, and the readable key=value context it exists for).
#SWARM_LOG_FORMAT=

# --- Cloudflare Tunnel (optional; docs/cloudflare-tunnel.md, Path C) ---
# Token for a dashboard-created tunnel (Cloudflare Zero Trust → Networks →
# Tunnels → "Install and run a connector"). Leave both unset to skip it
# entirely and run cloudflared yourself (Paths A/B), or fill both in to have
# Compose run it as a container alongside the rest of the stack.
CLOUDFLARE_TUNNEL_TOKEN=
# Activates the cloudflared service above — docker compose reads this itself.
COMPOSE_PROFILES=tunnel

# --- Ports (host-side) ---
# Offset from Cascade's defaults (router 3000, Postgres 5432, Redis 6379) so
# both stacks can run in parallel without a host-port clash. Only the published
# host ports change; inside the compose network the services still listen on
# their standard ports.
#
# The API server runs on the host (not in Compose) and reads API_PORT.
# Default 3101 is offset from Cascade's dashboard default 3001 and ROUTER_PORT (3100).
ROUTER_PORT=3100
API_PORT=3101
POSTGRES_PORT=5433
REDIS_PORT=6380
